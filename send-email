#!/usr/bin/env bash

# Check for help option
for arg in "$@"; do
  if [[ "$arg" == "--help" ]]; then
    echo "Usage: $0 [options]"
    echo "Options:"
    echo "  -r <recipient>    Recipient email address"
    echo "  -s <subject>      Subject of the email"
    echo "  -a <attachment>   Path to attachment file"
    echo "  -b <body>         Body of the email"
    echo "  --help            Show this usage information"
    echo ""
    echo "Required Environment Variables:"
    echo "  DEFAULT_ADMIN_EMAIL"
    echo "  SCRIPT_SMTP_SERVER"
    echo "  SCRIPT_SMTP_PORT"
    echo "  SCRIPT_SMTP_LOGIN"
    echo "  SCRIPT_SMTP_KEY"
    exit 0
  fi
done

# Check for required environment variables
if [ -z "$DEFAULT_ADMIN_EMAIL" ] || [ -z "$SCRIPT_SMTP_SERVER" ] || [ -z "$SCRIPT_SMTP_PORT" ] || [ -z "$SCRIPT_SMTP_LOGIN" ] || [ -z "$SCRIPT_SMTP_KEY" ]; then
  echo "Error: Please set the required environment variables: DEFAULT_ADMIN_EMAIL, SCRIPT_SMTP_SERVER, SCRIPT_SMTP_PORT, SCRIPT_SMTP_LOGIN, SCRIPT_SMTP_KEY"
  exit 1
fi

# Default recipient
DEFAULT_RECIPIENT="$DEFAULT_ADMIN_EMAIL"

# Initialize variables
recipient=""
subject=""
attachment=""
body=""

# Parse command-line options
while getopts "r:s:a:b:" opt; do
  case $opt in
    r) recipient="$OPTARG" ;;
    s) subject="$OPTARG" ;;
    a) attachment="$OPTARG" ;;
    b) body="$OPTARG" ;;
    \?) echo "Invalid option: -$OPTARG" >&2; exit 1 ;;
  esac
done

# Set recipient to default if not provided
if [ -z "$recipient" ]; then
  recipient="$DEFAULT_RECIPIENT"
fi

# Check for required options
if [ -z "$subject" ] || [ -z "$body" ]; then
  echo "Usage: $0 -s <subject> -b <body> [-r <recipient>] [-a <attachment>]"
  exit 1
fi

# Execute pop command
if [[ "$SCRIPT_SMTP_LOGIN" == "resend" ]]; then
  # Use Resend API support if login is 'resend'
  cmd=(pop --from "$DEFAULT_ADMIN_EMAIL" --to "$recipient" --subject "$subject" --body "$body" --resend.key "$SCRIPT_SMTP_KEY")
else
  # Use generic SMTP
  cmd=(pop --from "$DEFAULT_ADMIN_EMAIL" --to "$recipient" --subject "$subject" --body "$body" --smtp.host "$SCRIPT_SMTP_SERVER" --smtp.port "$SCRIPT_SMTP_PORT" --smtp.username "$SCRIPT_SMTP_LOGIN" --smtp.password "$SCRIPT_SMTP_KEY" --smtp.encryption "ssl")
fi

if [[ -n "$attachment" ]]; then
  "${cmd[@]}" --attach "$attachment"
else
  "${cmd[@]}"
fi

echo "Email sent to $recipient"
